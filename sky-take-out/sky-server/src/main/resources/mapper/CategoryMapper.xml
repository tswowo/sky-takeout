<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.CategoryMapper">
    <!--新增分类-->
    <insert id="insert">
        INSERT INTO category (id,type,name,sort,status,create_time,update_time,create_user,update_user)
        VALUES (#{id},#{type},#{name},#{sort},#{status},NOW(),NOW(),#{createUser},#{createUser})
    </insert>
    <!--修改分类-->
    <update id="update">
        UPDATE category
        SET name = #{name},
            sort = #{sort},
            type = #{type},
            update_time = NOW(),
            update_user = #{updateUser},
            <if test="status!=null">
                status = #{status}
            </if>
        WHERE id = #{id}
    </update>
    <!--根据id删除分类-->
    <delete id="deleteById">
        DELETE
        FROM category
        WHERE id = #{id}
    </delete>
    <!--分类分页查询-->
    <select id="categoryPageQuery" resultType="com.sky.entity.Category">
        SELECT id,type,name,sort,status,create_time,update_time,create_user,update_user
        FROM category
        <where>
            <if test="name != null and name != ''">
                name like '%#{name}%'
            </if>
            <if test="type != null">
                and type = #{type}
            </if>
        </where>
        ORDER BY sort,id
    </select>
    <!--根据类型查询分类-->
    <select id="listCategory" resultType="com.sky.entity.Category">
        SELECT id,type,name,sort,status,create_time,update_time,create_user,update_user
        FROM category
        <where>
            <if test="type != null">
                type = #{type}
            </if>
        </where>
        ORDER BY sort,id
    </select>
    <!--查询该分类下是否有菜品-->
    <select id="countDishByCategoryId" resultType="java.lang.Integer">
        SELECT count(*)
        FROM dish
        WHERE category_id = #{categoryId}
    </select>
    <!--查询该分类下是否有套餐-->
    <select id="countSetmealByCategoryId" resultType="java.lang.Integer">
        SELECT count(*)
        FROM setmeal
        WHERE category_id = #{categoryId}
    </select>
</mapper>
